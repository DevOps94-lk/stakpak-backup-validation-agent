DB_USER=stakpak_user
DB_PASSWORD=StrongPassword123!
DB_NAME=stakpak_agent_db
STAGING_DB_NAME=stakpak_staging_db
BACKUP_DIR=/root/.stakpak/backups
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Slack tokens (optional — needed for Slack channel)
# bot_token → Slack App → OAuth & Permissions → Bot User OAuth Token
# app_token → Slack App → Basic Information → App-Level Tokens
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_TOKEN=xapp-your-app-token
